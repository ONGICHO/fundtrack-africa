# Application
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://fundtrack_user:fundtrack_secure_password_2024@localhost:5432/fundtrack_africa
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fundtrack_africa
DB_USER=fundtrack_user
DB_PASSWORD=fundtrack_secure_password_2024

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=7d

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ML Engine
ML_ENGINE_URL=http://localhost:8000
ML_ENGINE_API_KEY=your_ml_api_key

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@fundtrack-africa.com

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=http://localhost:3000

# Frontend URLs
FRONTEND_URL=http://localhost:3000

# AWS Configuration (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=fundtrack-africa-bucket

# Security
BCRYPT_ROUNDS=10
SESSION_SECRET=your_session_secret

# Feature Flags
ENABLE_ANOMALY_DETECTION=true
ENABLE_PREDICTIVE_ANALYTICS=true
ENABLE_REAL_TIME_ALERTS=true

# Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
ENABLE_PERFORMANCE_MONITORING=true

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100